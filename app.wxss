page {
  background: #f7f4ee;
  color: #26312a;
  font-size: 28rpx;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(42, 67, 52, 0.08);
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f3127;
  margin-bottom: 16rpx;
}

.subtle {
  color: #748176;
  font-size: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2f7d57 0%, #6ea54a 100%);
  color: #fff;
  border-radius: 999rpx;
  font-weight: 600;
}

.btn-ghost {
  background: #eef5ef;
  color: #2f7d57;
  border-radius: 999rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ef;
  color: #2f7d57;
  font-size: 22rpx;
}

