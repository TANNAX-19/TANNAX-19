<view class="page" wx:if="{{order}}">
  <view class="card head">
    <view class="head-top">
      <view>
        <view class="section-title">订单状态</view>
        <view class="subtle">{{order.id}}</view>
      </view>
      <view class="status-pill">{{order.status}}</view>
    </view>
    <view class="timeline">
      <view class="timeline-item">创建时间：{{order.createdAtText}}</view>
      <view class="timeline-item">支付状态：{{order.paymentText}}</view>
      <view class="timeline-item">物流信息：{{order.logisticsText}}</view>
      <view class="timeline-item">运单号：{{order.trackingText}}</view>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">收货信息</view>
    <view class="subtle">{{order.addressText}}</view>
    <view class="subtle">{{order.customer.name}}</view>
    <view class="subtle">{{order.customer.source}}</view>
  </view>

  <view class="section card">
    <view class="section-title">商品明细</view>
    <view class="goods" wx:for="{{order.items}}" wx:key="id">
      <view class="goods-name">{{item.name}}</view>
      <view class="goods-row">
        <text class="subtle">x{{item.quantity}}</text>
        <text class="goods-price">{{item.subtotalText}}</text>
      </view>
    </view>
    <view class="order-total-row">
      <text>合计</text>
      <text class="order-total">{{order.amountText}}</text>
    </view>
  </view>

  <view class="actions">
    <button class="btn-primary action" wx:if="{{order.statusCode === 'pending_payment'}}" bindtap="payNow">去支付</button>
    <button class="btn-ghost action" bindtap="refresh">刷新物流</button>
  </view>
</view>
