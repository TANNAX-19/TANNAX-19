.checkout-head {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.address-item {
  border: 1rpx solid #e4ebe5;
  border-radius: 22rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
  background: #fff;
}

.address-item.active {
  border-color: #2f7d57;
  box-shadow: 0 0 0 3rpx rgba(47, 125, 87, 0.08);
}

.address-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.address-name {
  font-weight: 700;
}

.address-line {
  color: #5e6c63;
  margin-top: 4rpx;
}

.address-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.action {
  flex: 1;
}

.goods {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf0eb;
}

.goods-name {
  font-weight: 600;
  margin-bottom: 8rpx;
}

.goods-row,
.order-total-row,
.checkout-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price,
.order-total {
  font-weight: 800;
  color: #1f5c40;
}

.order-total-row {
  padding-top: 18rpx;
}

.note {
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  border: 1rpx solid #e4ebe5;
  border-radius: 20rpx;
  padding: 18rpx;
  background: #fff;
}

.empty-tip {
  color: #718076;
  background: #f8fbf8;
  border-radius: 18rpx;
  padding: 18rpx;
}

.checkout-bar {
  margin: 24rpx 0 32rpx;
  padding: 20rpx 24rpx;
}

.checkout-status {
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #1f5c40;
}

.checkout-btn {
  min-width: 240rpx;
}

