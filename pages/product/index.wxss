.detail-hero {
  padding: 28rpx;
  background: linear-gradient(135deg, #fdfcf8 0%, #eef6ef 100%);
  margin-bottom: 24rpx;
}

.detail-top,
.detail-price-row,
.buy-row,
.buy-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-mark {
  color: #2f7d57;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-badge {
  color: #fff;
  background: linear-gradient(135deg, #2f7d57 0%, #6ea54a 100%);
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.detail-name {
  margin-top: 16rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.detail-subtitle {
  margin-top: 12rpx;
  color: #65746b;
}

.detail-price-row {
  margin-top: 18rpx;
}

.detail-price {
  font-size: 40rpx;
  font-weight: 800;
  color: #1f5c40;
}

.detail-old-price {
  color: #98a29a;
  text-decoration: line-through;
}

.detail-tags {
  margin-top: 18rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.info,
.buy-panel {
  padding: 24rpx;
}

.info-row {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  color: #4c5b52;
}

.info-label {
  width: 84rpx;
  color: #7a867d;
}

.info-value {
  flex: 1;
}

.buy-row {
  margin-bottom: 18rpx;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.step-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 20rpx;
  background: #eef5ef;
  color: #2f7d57;
  font-weight: 700;
}

.step-value {
  min-width: 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}

.buy-summary {
  padding: 20rpx 0;
  border-top: 1rpx solid #edf0eb;
  border-bottom: 1rpx solid #edf0eb;
}

.buy-total {
  font-size: 38rpx;
  font-weight: 800;
  color: #1f5c40;
}

.buy-actions {
  margin-top: 22rpx;
  display: flex;
  gap: 16rpx;
}

.action {
  flex: 1;
}

