.head {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.addr-card {
  border: 1rpx solid #e4ebe5;
  border-radius: 22rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.addr-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.addr-name {
  font-weight: 700;
}

.addr-mobile,
.addr-source,
.addr-line {
  color: #5f6d64;
  margin-top: 6rpx;
}

.addr-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}

.mini {
  font-size: 22rpx;
  padding: 10rpx 14rpx;
}

.danger {
  color: #b5524f;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.field {
  border: 1rpx solid #e4ebe5;
  border-radius: 18rpx;
  padding: 16rpx;
  background: #fff;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 18rpx 0 6rpx;
}

.action {
  flex: 1;
}

.empty-tip {
  color: #718076;
  background: #f8fbf8;
  border-radius: 18rpx;
  padding: 18rpx;
}

