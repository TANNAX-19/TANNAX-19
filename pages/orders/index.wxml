<view class="page">
  <view class="section-title">订单管理</view>
  <scroll-view scroll-x class="tabs">
    <view
      class="tab {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="switchTab"
    >{{item.label}}</view>
  </scroll-view>

  <view wx:if="{{visibleOrders.length}}">
    <view class="card order-card" wx:for="{{visibleOrders}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="order-top">
        <text class="order-id">{{item.id}}</text>
        <text class="status">{{item.status}}</text>
      </view>
      <view class="order-item-list">{{item.items[0].name}} 等{{item.items.length}}件商品</view>
      <view class="order-bottom">
        <text class="order-time">{{item.createdAtText}}</text>
        <text class="order-amount">{{item.amountText}}</text>
      </view>
    </view>
  </view>

  <view wx:else class="card empty">
    <view class="empty-title">暂无订单</view>
    <view class="subtle">你在首页下单后，这里会同步显示订单状态</view>
  </view>
</view>
