.hero {
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fdfcf8 0%, #eef6ef 100%);
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.hero-kicker {
  color: #2f7d57;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 800;
  color: #1d2d24;
}

.hero-subtitle {
  margin-top: 10rpx;
  color: #66756b;
  font-size: 24rpx;
}

.hero-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #2f7d57 0%, #6ea54a 100%);
  color: #fff;
  font-size: 22rpx;
}

.hero-stats {
  display: flex;
  margin-top: 24rpx;
  gap: 16rpx;
}

.stat {
  flex: 1;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 22rpx;
  padding: 18rpx 14rpx;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #20362b;
}

.stat-label {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #738278;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.product {
  padding: 24rpx;
}

.product-top,
.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-name {
  font-size: 32rpx;
  font-weight: 700;
}

.product-badge {
  font-size: 20rpx;
  color: #2f7d57;
  background: #eef5ef;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.product-subtitle {
  margin-top: 10rpx;
  color: #6f7b72;
}

.product-tags {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.price {
  font-size: 34rpx;
  font-weight: 800;
  color: #1f5c40;
}

.old-price {
  margin-left: 12rpx;
  color: #9aa49c;
  text-decoration: line-through;
  font-size: 22rpx;
}

.product-link {
  color: #2f7d57;
  font-weight: 600;
}

.guide {
  padding: 24rpx;
}

.guide-item {
  margin-top: 12rpx;
  color: #5c6b61;
}

